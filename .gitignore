!.vscode/extensions.json
*.swp
*.swo
*~
.project
.classpath
.settings/
.factorypath
nbproject/private/

# ---------- Java / Maven ----------
target/
build/
out/
bin/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
