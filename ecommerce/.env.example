# =====================================================================
# Environment template — copy to `.env` and fill in real values for local dev.
#
#   cp .env.example .env
#
# `.env` is gitignored. NEVER commit real secrets.
#
# IMPORTANT: Most service-specific values (DB credentials per service) are
# read from each service's own application.yaml `${VAR:default}` fallback.
# Variables here override those defaults when running services with this
# `.env` sourced (e.g. `docker compose up`, or `set -a && source .env`).
# =====================================================================

# ────────────────────────────────────────────────────────────────────
# Shared secrets — used by multiple services
# ────────────────────────────────────────────────────────────────────
# JWT signing key (HS256) — must be ≥32 chars. Used by auth-service to sign,
# all other services to verify via common-lib JwtTokenValidator.
JWT_SECRET=change-me-change-me-change-me-change-me-please-32chars
JWT_ISSUER=hieu.com
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL_DAYS=7

# Internal service-to-service token (REST clients)
INTERNAL_TOKEN=change-me-internal-token-min-32-chars-please

# Eureka basic-auth credentials
EUREKA_USERNAME=admin
EUREKA_PASSWORD=admin123
EUREKA_URL=http://admin:admin123@localhost:8761/eureka/
EUREKA_URI=http://admin:admin123@localhost:8761/eureka/
EUREKA_HOSTNAME=localhost
EUREKA_ENABLED=true
EUREKA_SELF_PRESERVATION=true

# CORS allow-list (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Auth cookie behaviour (set Secure=true behind HTTPS)
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax

# ────────────────────────────────────────────────────────────────────
# Infrastructure (docker-compose containers)
# ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

KAFKA_BOOTSTRAP=localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

ELASTICSEARCH_URI=http://localhost:9200

# Mail (mailhog default — port 1025)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ────────────────────────────────────────────────────────────────────
# Per-service Postgres credentials (used by docker-compose)
# Each service has its own DB. Override DB_URL/DB_USER/DB_PASSWORD
# per service container (recommended for prod) or per shell session.
# ────────────────────────────────────────────────────────────────────
POSTGRES_AUTH_DB=authdb
POSTGRES_AUTH_USER=authuser
POSTGRES_AUTH_PASSWORD=authpass

POSTGRES_CATALOG_DB=catalogdb
POSTGRES_CATALOG_USER=cataloguser
POSTGRES_CATALOG_PASSWORD=catalogpass

POSTGRES_CART_DB=cartdb
POSTGRES_CART_USER=cartuser
POSTGRES_CART_PASSWORD=cartpass

POSTGRES_ORDER_DB=orderdb
POSTGRES_ORDER_USER=orderuser
POSTGRES_ORDER_PASSWORD=orderpass

POSTGRES_PAYMENT_DB=paymentdb
POSTGRES_PAYMENT_USER=paymentuser
POSTGRES_PAYMENT_PASSWORD=paymentpass

POSTGRES_SHIPPING_DB=shippingdb
POSTGRES_SHIPPING_USER=shippinguser
POSTGRES_SHIPPING_PASSWORD=shippingpass

POSTGRES_INVENTORY_DB=inventorydb
POSTGRES_INVENTORY_USER=inventoryuser
POSTGRES_INVENTORY_PASSWORD=inventorypass

POSTGRES_NOTIFICATION_DB=notificationdb
POSTGRES_NOTIFICATION_USER=notificationuser
POSTGRES_NOTIFICATION_PASSWORD=notificationpass

POSTGRES_USERPROFILE_DB=userprofiledb
POSTGRES_USERPROFILE_USER=userprofileuser
POSTGRES_USERPROFILE_PASSWORD=userprofilepass

POSTGRES_VOUCHER_DB=voucherdb
POSTGRES_VOUCHER_USER=voucheruser
POSTGRES_VOUCHER_PASSWORD=voucherpass

POSTGRES_FLASHSALE_DB=flashsaledb
POSTGRES_FLASHSALE_USER=flashsaleuser
POSTGRES_FLASHSALE_PASSWORD=flashsalepass

# ────────────────────────────────────────────────────────────────────
# Service URLs (REST inter-service calls)
# ────────────────────────────────────────────────────────────────────
CATALOG_SERVICE_URL=http://localhost:8083
CART_SERVICE_URL=http://localhost:8084
ORDER_SERVICE_URL=http://localhost:8085
PAYMENT_SERVICE_URL=http://localhost:8086
SHIPPING_SERVICE_URL=http://localhost:8087
INVENTORY_SERVICE_URL=http://localhost:8088
VOUCHER_SERVICE_URL=http://localhost:8094

# gRPC addresses
CATALOG_GRPC_ADDRESS=localhost:9093
CART_GRPC_ADDRESS=localhost:9094
INVENTORY_GRPC_ADDRESS=localhost:9098

# ────────────────────────────────────────────────────────────────────
# Payment provider secrets (REQUIRED for prod, optional for local)
# ────────────────────────────────────────────────────────────────────
SEPAY_WEBHOOK_API_KEY=
SEPAY_WEBHOOK_ALLOW_INSECURE=true
MOMO_SECRET_KEY=

# ────────────────────────────────────────────────────────────────────
# Analytics
# ────────────────────────────────────────────────────────────────────
ANALYTICS_INDEX_PREFIX=analytics-events
