# Environment template for auth-service.
# Copy to `.env` and customize for local dev. `.env` is gitignored.
# Spring Boot loads `.env` automatically via spring.config.import in application.yaml.

GRPC_PORT=9091
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
KAFKA_BOOTSTRAP=localhost:9092
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://localhost:5433/authdb
DB_USER=authuser
DB_PASSWORD=authpass
JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
JPA_DDL=validate
FLYWAY_ENABLED=true
SERVER_PORT=8081
JWT_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=hieu.com
EUREKA_URL=http://admin:admin123@localhost:8761/eureka/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
