# Environment template for catalog-service.
# Copy to `.env` and customize for local dev. `.env` is gitignored.
# Spring Boot loads `.env` automatically via spring.config.import in application.yaml.

GRPC_PORT=9093
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://localhost:5434/catalogdb
DB_USER=cataloguser
DB_PASSWORD=catalogpass
JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
JPA_DDL=validate
FLYWAY_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
KAFKA_BOOTSTRAP=localhost:9092
SERVER_PORT=8083
JWT_SECRET=change-me-change-me-change-me-change-me-please-32chars
EUREKA_URL=http://admin:admin123@localhost:8761/eureka/
