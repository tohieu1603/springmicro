# Environment template for flash-sale-service.
# Copy to `.env` and customize for local dev. `.env` is gitignored.
# Spring Boot loads `.env` automatically via spring.config.import in application.yaml.

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
JWT_SECRET=mySecretKeyForJWTTokenGenerationThatIsAtLeast256BitsLongForHS256Algorithm
EUREKA_URI=http://admin:admin123@localhost:8761/eureka/
EUREKA_ENABLED=true
