# Environment template for order-service.
# Copy to `.env` and customize for local dev. `.env` is gitignored.
# Spring Boot loads `.env` automatically via spring.config.import in application.yaml.

GRPC_PORT=9095
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://localhost:5436/orderdb
DB_USER=orderuser
DB_PASSWORD=orderpass
JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
JPA_DDL=validate
FLYWAY_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
KAFKA_BOOTSTRAP=localhost:9092
SERVER_PORT=8085
JWT_SECRET=change-me-change-me-change-me-change-me-please-32chars
INTERNAL_TOKEN=change-me-internal-token-min-32-chars-please
EUREKA_URL=http://admin:admin123@localhost:8761/eureka/
CATALOG_GRPC_ADDRESS=localhost:9093
CART_GRPC_ADDRESS=localhost:9094
INVENTORY_GRPC_ADDRESS=localhost:9098
CATALOG_SERVICE_URL=http://localhost:8083
CART_SERVICE_URL=http://localhost:8084
PAYMENT_SERVICE_URL=http://localhost:8086
SHIPPING_SERVICE_URL=http://localhost:8087
INVENTORY_SERVICE_URL=http://localhost:8088
VOUCHER_SERVICE_URL=http://localhost:8094
