# Server-side base URL (used by Next route handlers + RSC fetches).
# Reach the Java api-gateway directly so cookies/JWT pass through.
API_BASE_URL=http://localhost:8080

# Browser-facing base URL — same gateway, but routed via Next route handlers
# (/api/proxy/*) so HttpOnly cookies stay attached. Leave empty to use relative.
NEXT_PUBLIC_API_BASE=

# Brand
NEXT_PUBLIC_BRAND_NAME=Luxury Mart
NEXT_PUBLIC_BRAND_TAGLINE=Mua sắm đẳng cấp, giao hàng toàn quốc

# Canonical absolute URL — used by JSON-LD, OG, sitemap.xml, robots.txt
NEXT_PUBLIC_SITE_URL=https://luxury-mart.vn

# Shared secret for /api/internal/revalidate. BE Kafka consumers send this
# header to bust Next's data cache after product updates.
REVALIDATE_SECRET=change-me-in-prod

# Auth cookie names (must align with what auth-service issues if cookies forwarded)
AUTH_COOKIE_ACCESS=lm_access
AUTH_COOKIE_REFRESH=lm_refresh
